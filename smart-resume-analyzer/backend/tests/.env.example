# ─── Test Environment Variables ───
# Use these for local testing only. Never commit real keys.

# Mock database for tests
DATABASE_URL=postgresql+asyncpg://test_user:test_pass@localhost:5432/smart_resume_test

# Test JWT settings
SECRET_KEY=test-secret-key-at-least-32-characters-long
ALGORITHM=HS256

# Test API Keys (use mock strings or sandbox keys)
GEMINI_API_KEY=test-gemini-api-key

# Test Google OAuth
GOOGLE_CLIENT_ID=test-client-id
GOOGLE_CLIENT_SECRET=test-client-secret

# General
ENVIRONMENT=testing
UPLOAD_DIR=./test_uploads
