# ──────────────────────────────────────────────────────────────
# Smart Resume Analyzer — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/smart_resume_db

# JWT Security
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# AI - Gemini (get from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-from-aistudio

# Redis
REDIS_URL=redis://redis:6379

# App
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
